# ─── Docaa Simulator — Environment Variables ───────────────
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Security — CHANGE THESE! Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d
ADMIN_SECRET=CHANGE_THIS_SUPERADMIN_PASSWORD

# Anthropic API Key (one key for all students)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Database path
DB_PATH=./data/simulator.db

# Frontend URL (for CORS)
FRONTEND_URL=https://sim.docaa.net

# Rate limiting
MAX_AI_REQUESTS_PER_MINUTE=30
MAX_LOGIN_ATTEMPTS=5
